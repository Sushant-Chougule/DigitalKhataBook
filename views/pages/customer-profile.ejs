<div class="row g-4">
    <div class="col-md-4">
        <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show">
                <%= __(success) %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                <%= __(error) %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        <% } %>

        <div class="card mb-4">
            <div class="card-body text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-person-circle text-primary" style="font-size: 5rem;"></i>
                </div>
                <h4 class="auto-translate"><%= customer.full_name %></h4>
                <p class="mb-1 text-muted"><i class="bi bi-hash me-1"></i><%= customer.customer_code %></p>     
                <p class="text-muted"><i class="bi bi-phone me-1"></i><%= customer.mobile %></p>
                <div class="p-3 bg-light rounded-3 mb-3 text-dark">
                    <h6 class="text-muted mb-1"><%= __("current_net_balance") %></h6>
                    <h3 class="<%= customer.balance >= 0 ? 'text-success' : 'text-danger' %> mb-0">
                        ₹<%= Math.abs(customer.balance).toFixed(2) %>
                    </h3>
                    <small class="fw-medium"><%= customer.balance >= 0 ? __("owner_pays") : __("customer_pays") %></small>
                </div>
                <button class="btn btn-outline-primary w-100 mb-2" data-bs-toggle="modal" data-bs-target="#editCustomerModal">
                    <i class="bi bi-pencil me-2"></i> <%= __("edit") %> <%= __("customers") %>
                </button>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><%= __("business_wise_summary") %></div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <% businessSummary.forEach(s => { %>
                        <li class="list-group-item d-flex justify-content-between p-3">
                            <span class="auto-translate"><%= s.business_name || 'Direct / Payments' %></span>
                            <span class="<%= s.net_amount >= 0 ? 'text-success' : 'text-danger' %> fw-bold">    
                                ₹<%= Math.abs(s.net_amount).toFixed(2) %>
                            </span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><%= __("transaction_history") %> / <%= __("ledger") %></span>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-success" onclick="exportTableToCSV('<%= customer.full_name.replace(' ', '_') %>_ledger.csv')"><i class="bi bi-file-earmark-excel me-2"></i> <%= __("export_excel") %></button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer me-2"></i> <%= __("print") %></button>
                    <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addTransactionModal"><i class="bi bi-plus-lg me-2"></i> <%= __("add_transaction") %></button>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th><%= __("date") %></th>
                                <th><%= __("business") %></th>
                                <th><%= __("type") %></th>
                                <th><%= __("amount") %></th>
                                <th><%= __("balance") %></th>
                                <th><%= __("remarks") %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% transactions.forEach(t => { %>
                                <tr>
                                    <td class="small"><%= formatDate(t.date) %></td>
                                    <td class="auto-translate"><%= t.business_name || 'N/A' %></td>
                                    <td>
                                        <span class="badge rounded-pill bg-light text-dark border">
                                            <%= __(t.type) %>
                                        </span>
                                    </td>
                                    <td class="<%= ['milk_collection', 'customer_payment', 'owner_payment'].includes(t.type) ? 'text-success' : 'text-danger' %>">
                                        ₹<%= t.amount.toFixed(2) %>
                                    </td>
                                    <td class="<%= t.runningBalance >= 0 ? 'text-success' : 'text-danger' %> fw-bold">
                                        ₹<%= Math.abs(t.runningBalance).toFixed(2) %>
                                    </td>
                                    <td class="small text-muted"><%= t.remarks %></td>
                                </tr>
                            <% }) %>
                            <% if (transactions.length === 0) { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No transactions found</td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Edit Customer Modal -->
<div class="modal fade" id="editCustomerModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><%= __("edit") %> <%= __("customers") %></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/customers/edit/<%= customer.id %>" method="POST">
                <div class="modal-body text-dark text-start">
                    <div class="mb-3">
                        <label class="form-label"><%= __("customer_code") %> (Permanent)</label>
                        <input type="text" name="customer_code" class="form-control bg-light" value="<%= customer.customer_code %>" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("full_name") %></label>
                        <input type="text" name="full_name" class="form-control" value="<%= customer.full_name %>" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("mobile") %></label>
                        <input type="text" name="mobile" class="form-control" value="<%= customer.mobile %>" required maxlength="10" minlength="10" pattern="\d{10}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("address") %></label>
                        <textarea name="address" class="form-control" rows="2"><%= customer.address %></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("village_city") %></label>
                        <input type="text" name="village_city" class="form-control" value="<%= customer.village_city %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("notes") %></label>
                        <textarea name="notes" class="form-control" rows="2"><%= customer.notes %></textarea>   
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= __("cancel") %></button>
                    <button type="submit" class="btn btn-primary"><%= __("save") %></button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Transaction Modal (Shortcut) -->
<div class="modal fade" id="addTransactionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><%= __("quick_transaction") %>: <%= customer.full_name %></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="/transactions/add" method="POST" id="quickTransForm">
                <input type="hidden" name="customer_id" value="<%= customer.id %>">
                <input type="hidden" name="redirect_to" value="profile">
                <div class="modal-body text-dark text-start">
                    <div class="mb-3">
                        <label class="form-label"><%= __("type") %></label>
                        <select name="type" id="quickTransType" class="form-select" required>
                            <option value=""><%= __("type") %></option>
                            <option value="milk_collection"><%= __("milk_collection") %> (+)</option>
                            <option value="grocery_purchase"><%= __("grocery_purchase") %> (-)</option>
                            <option value="medical_purchase"><%= __("medical_purchase") %> (-)</option>
                            <option value="hospital_expense"><%= __("hospital_expense") %> (-)</option>
                            <option value="borrowing"><%= __("borrowing") %> (-)</option>
                            <option value="owner_payment"><%= __("owner_payment") %> (+)</option>
                            <option value="customer_payment"><%= __("customer_payment") %> (+)</option>
                            <option value="settlement">Settlement (+)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("business") %></label>
                        <select name="business_id" id="quickBizSelect" class="form-select" required>
                            <option value="">Select Business</option>
                            <option value="1" data-name="Dairy Farm">Dairy Farm</option>
                            <option value="2" data-name="Grocery Shop">Grocery Shop</option>
                            <option value="3" data-name="Medical Store">Medical Store</option>
                            <option value="4" data-name="Hospital">General Hospital</option>
                            <option value="5" data-name="Cash">Cash</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("amount") %> (₹)</label>
                        <input type="number" step="0.01" name="amount" id="quickAmount" class="form-control" required placeholder="0.00">
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("date") %></label>
                        <input type="date" id="quickDate" name="date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><%= __("remarks") %></label>
                        <input type="text" name="remarks" id="quickRemarks" class="form-control" placeholder="Optional notes">    
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal"><%= __("cancel") %></button>
                    <button type="button" class="btn btn-primary" id="preSaveBtn"><%= __("add_transaction") %></button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Quick Confirmation Modal -->
<div class="modal fade" id="quickConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Confirm Transaction</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-dark text-start">
                <p class="text-muted mb-4">Are you sure you want to save this transaction?</p>
                <div class="row mb-3">
                    <div class="col-5 text-muted">Type:</div>
                    <div class="col-7 fw-bold" id="qConfType"></div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-muted">Business:</div>
                    <div class="col-7 fw-bold" id="qConfBusiness"></div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-muted">Amount:</div>
                    <div class="col-7 fw-bold text-primary fs-5" id="qConfAmount"></div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" id="qConfirmSaveBtn">Confirm Transaction</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Quick Transaction Mapping Logic
    const quickBizMapping = {
        'milk_collection': 'Dairy Farm',
        'grocery_purchase': 'Grocery Shop',
        'medical_purchase': 'Medical Store',
        'hospital_expense': 'Hospital',
        'borrowing': 'Cash',
        'owner_payment': 'Cash',
        'customer_payment': 'Cash',
        'settlement': 'Cash'
    };
    const quickLockedTypes = ['milk_collection', 'grocery_purchase', 'medical_purchase', 'hospital_expense'];       

    document.getElementById('quickTransType').addEventListener('change', function() {
        const type = this.value;
        const bizSelect = document.getElementById('quickBizSelect');
        const targetName = quickBizMapping[type];

        if (type && targetName) {
            const options = Array.from(bizSelect.options);
            const targetOption = options.find(opt => opt.getAttribute('data-name') === targetName);
            if (targetOption) bizSelect.value = targetOption.value;

            bizSelect.disabled = quickLockedTypes.includes(type);

            const oldHidden = document.getElementById('quickHiddenBiz');
            if (oldHidden) oldHidden.remove();

            if (bizSelect.disabled) {
                const hidden = document.createElement('input');
                hidden.type = 'hidden';
                hidden.name = 'business_id';
                hidden.id = 'quickHiddenBiz';
                hidden.value = bizSelect.value;
                document.getElementById('quickTransForm').appendChild(hidden);
            }
        }
    });

    const qConfirmModal = new bootstrap.Modal(document.getElementById('quickConfirmModal'));

    document.getElementById('preSaveBtn').addEventListener('click', function() {
        // Populate
        document.getElementById('qConfType').innerText = document.getElementById('quickTransType').options[document.getElementById('quickTransType').selectedIndex].text;
        document.getElementById('qConfBusiness').innerText = document.getElementById('quickBizSelect').options[document.getElementById('quickBizSelect').selectedIndex].text;
        document.getElementById('qConfAmount').innerText = '₹' + document.getElementById('quickAmount').value;    

        qConfirmModal.show();
    });

    document.getElementById('qConfirmSaveBtn').addEventListener('click', function() {
        document.getElementById('quickBizSelect').disabled = false;
        document.getElementById('quickTransForm').submit();
    });
});
</script>
