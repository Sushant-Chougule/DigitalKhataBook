<div class="row g-4">
    <!-- Stat Cards -->
    <div class="col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-light-primary me-3">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0"><%= __("total_customers") %></h6>
                    <h4 class="mb-0"><%= stats.totalCustomers %></h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-light-info me-3">
                    <i class="bi bi-shop"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0"><%= __("total_businesses") %></h6>
                    <h4 class="mb-0"><%= stats.totalBusinesses %></h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-light-success me-3">
                    <i class="bi bi-arrow-up-circle"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0"><%= __("owner_payable") %></h6>
                    <h4 class="mb-0 text-success">₹<%= stats.ownerPayable.toFixed(2) %></h4>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card p-3">
            <div class="d-flex align-items-center">
                <div class="icon-box bg-light-danger me-3">
                    <i class="bi bi-arrow-down-circle"></i>
                </div>
                <div>
                    <h6 class="text-muted mb-0"><%= __("owner_receivable") %></h6>
                    <h4 class="mb-0 text-danger">₹<%= stats.ownerReceivable.toFixed(2) %></h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><%= __("business_wise_summary") %></div>
            <div class="card-body">
                <div style="position: relative; height:300px; width: 100%;">
                    <canvas id="businessChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header"><%= __("balance") %> <%= __("search_results") %></div>
            <div class="card-body">
                <div style="position: relative; height:300px; width: 100%;">
                    <canvas id="balanceChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><%= __("recent_transactions") %></span>
                <a href="/transactions" class="btn btn-sm btn-outline-primary"><%= __("all_transactions") %></a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-dark">
                            <tr>
                                <th><%= __("date") %></th>
                                <th><%= __("customers") %></th>
                                <th><%= __("business") %></th>
                                <th><%= __("type") %></th>
                                <th><%= __("amount") %></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% recentTransactions.forEach(t => { %>
                                <tr>
                                    <td class="small"><%= formatDate(t.date) %></td>
                                    <td class="auto-translate"><%= t.customer_name %></td>
                                    <td><%= __(t.business_name) %></td>
                                    <td>
                                        <span class="badge rounded-pill bg-light text-dark border">
                                            <%= __(t.type) %>
                                        </span>
                                    </td>
                                    <td class="<%= ['milk_collection', 'customer_payment', 'owner_payment'].includes(t.type) ? 'text-success' : 'text-danger' %>">
                                        ₹<%= t.amount.toFixed(2) %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header"><%= __("top_customers") %></div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <% topCustomers.forEach(c => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <div>
                                <h6 class="mb-0 auto-translate"><%= c.full_name %></h6>
                                <small class="text-muted"><%= c.mobile %></small>
                            </div>
                            <span class="<%= c.balance >= 0 ? 'text-success' : 'text-danger' %> fw-bold">
                                ₹<%= Math.abs(c.balance).toFixed(2) %>
                            </span>
                        </li>
                    <% }) %>
                </ul>
            </div>
            <div class="card-footer bg-white border-0 text-center py-3">
                <a href="/customers" class="btn btn-sm btn-link text-decoration-none"><%= __("customers") %></a>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Business Chart
    const bizCtx = document.getElementById('businessChart').getContext('2d');
    new Chart(bizCtx, {
        type: 'doughnut',
        data: {
            labels: <%- JSON.stringify(businessStats.map(b => __(b.name))) %>,
            datasets: [{
                data: <%- JSON.stringify(businessStats.map(b => b.total)) %>,
                backgroundColor: ['#4361ee', '#10b981', '#f59e0b', '#f43f5e', '#0ea5e9'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom' }
            }
        }
    });

    // Balance Chart (Payable vs Receivable)
    const balCtx = document.getElementById('balanceChart').getContext('2d');
    new Chart(balCtx, {
        type: 'bar',
        data: {
            labels: ['<%= __("owner_payable") %>', '<%= __("owner_receivable") %>'],
            datasets: [{
                label: '<%= __("amount") %> (₹)',
                data: [<%= stats.ownerPayable %>, <%= stats.ownerReceivable %>],
                backgroundColor: ['#10b981', '#f43f5e'],
                borderRadius: 8,
                barThickness: 40
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { display: false }
                },
                x: {
                    grid: { display: false }
                }
            },
            plugins: {
                legend: { display: false }
            }
        }
    });
});
</script>
