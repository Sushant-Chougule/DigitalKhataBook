<div class="row g-4">
    <!-- Left Column: Transaction Form -->
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white"><%= __("add_transaction") %></div>
            <div class="card-body">
                <% if (success) { %>
                    <div class="alert alert-success alert-dismissible fade show">
                        <%= __(success) %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (error) { %>
                    <div class="alert alert-danger alert-dismissible fade show">
                        <%= __(error) %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <form action="/transactions/add" method="POST" id="transactionForm">
                    <!-- Customer Search -->
                    <div class="mb-3 position-relative">
                        <label class="form-label"><%= __("search") %> <%= __("customers") %> (<%= __("customer_code") %>, <%= __("full_name") %>, <%= __("mobile") %>)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" id="customerSearch" class="form-control" placeholder="<%= __("search") %>..." autocomplete="off">
                        </div>
                        <div id="searchResults" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; display: none; max-height: 200px; overflow-y: auto;"></div>
                        <input type="hidden" name="customer_id" id="customerId" required>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label"><%= __("full_name") %></label>
                            <input type="text" id="displayCustomerName" class="form-control bg-light auto-translate" readonly> 
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("type") %></label>
                            <select name="type" id="transType" class="form-select" required>
                                <option value=""><%= __("type") %></option>
                                <option value="milk_collection"><%= __("milk_collection") %> (+)</option>
                                <option value="grocery_purchase"><%= __("grocery_purchase") %> (-)</option>
                                <option value="medical_purchase"><%= __("medical_purchase") %> (-)</option>
                                <option value="hospital_expense"><%= __("hospital_expense") %> (-)</option>
                                <option value="borrowing"><%= __("borrowing") %> (-)</option>
                                <option value="owner_payment"><%= __("owner_payment") %> (+)</option>
                                <option value="customer_payment"><%= __("customer_payment") %> (+)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("business") %></label>
                            <select name="business_id" class="form-select">
                                <option value="">None / Cash</option>
                                <% businesses.forEach(b => { %>
                                    <option value="<%= b.id %>"><%= __(b.name) %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("amount") %> (₹)</label>
                            <input type="number" step="0.01" name="amount" id="amount" class="form-control" required placeholder="0.00">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("date") %></label>
                            <input type="date" name="date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("remarks") %></label>
                            <input type="text" name="remarks" class="form-control" placeholder="<%= __("remarks") %>">
                        </div>
                    </div>

                    <!-- Balance Preview -->
                    <div id="balancePreview" class="mt-4 p-3 border rounded-3 bg-light d-none text-dark">
                        <div class="row text-center">
                            <div class="col-md-4">
                                <small class="text-muted d-block"><%= __("balance") %></small>
                                <span id="currentBalance" class="fw-bold fs-5">₹0.00</span>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted d-block">Impact</small>
                                <span id="impactAmount" class="fw-bold fs-5">₹0.00</span>
                            </div>
                            <div class="col-md-4 border-start">
                                <small class="text-muted d-block"><%= __("net_balance") %></small>
                                <span id="newBalance" class="fw-bold fs-5">₹0.00</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary w-100 py-2 fs-5" id="submitBtn" disabled>  
                            <i class="bi bi-check-circle me-2"></i> <%= __("save_transaction") %>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Recent Transactions for Selected Customer -->
        <div id="customerTransactions" class="card d-none">
            <div class="card-header"><%= __("recent_transactions") %> (<%= __("customers") %>)</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="lastTransTable">
                        <thead class="bg-light">
                            <tr>
                                <th><%= __("date") %></th>
                                <th><%= __("type") %></th>
                                <th><%= __("business") %></th>
                                <th><%= __("amount") %></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Customer Info Panel -->
    <div class="col-md-4">
        <div id="customerSummary" class="sticky-top" style="top: 20px;">
            <div class="alert alert-info text-center py-4">
                <i class="bi bi-person-bounding-box fs-1 d-block mb-2"></i>
                Please select a customer to view summary
            </div>

            <div id="summaryContent" class="d-none">
                <div class="card mb-4 border-start border-4 border-primary">
                    <div class="card-body">
                        <h5 class="card-title mb-3 auto-translate" id="summName">--</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted"><%= __("customer_code") %>:</span>
                            <span id="summCode" class="fw-bold">--</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted"><%= __("mobile") %>:</span>
                            <span id="summMobile">--</span>
                        </div>
                        <div class="mt-3 p-3 bg-light rounded text-center text-dark">
                            <small class="text-muted"><%= __("net_balance") %></small>
                            <h3 id="summBalance" class="mb-0">₹0.00</h3>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><%= __("business_wise_summary") %></div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush" id="summBusiness">
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let currentCustBalance = 0;

document.getElementById('customerSearch').addEventListener('input', async function() {
    const query = this.value;
    const resDiv = document.getElementById('searchResults');

    if (query.length < 2) {
        resDiv.style.display = 'none';
        return;
    }

    const response = await fetch(`/customers/api/search?q=${encodeURIComponent(query)}`);
    const customers = await response.json();

    resDiv.innerHTML = '';
    if (customers.length > 0) {
        customers.forEach(c => {
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'list-group-item list-group-item-action py-2';
            item.innerHTML = `
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <strong class="d-block auto-translate">${c.full_name}</strong>
                        <small class="text-muted">${c.customer_code} | ${c.mobile}</small>
                    </div>
                </div>
            `;
            item.onclick = () => selectCustomer(c.customer_code);
            resDiv.appendChild(item);
        });
        resDiv.style.display = 'block';
        // Trigger auto-translate for new results
        if (typeof autoTranslate === 'function') autoTranslate();
    } else {
        resDiv.style.display = 'none';
    }
});

async function selectCustomer(code) {
    const resDiv = document.getElementById('searchResults');
    resDiv.style.display = 'none';
    document.getElementById('customerSearch').value = code;

    const response = await fetch(`/customers/api/${code}`);
    const data = await response.json();

    if (data.success) {
        const c = data.customer;
        currentCustBalance = c.balance;

        // Fill form
        document.getElementById('customerId').value = c.id;
        document.getElementById('displayCustomerName').value = c.full_name;
        document.getElementById('submitBtn').disabled = false;

        // Show Preview
        document.getElementById('balancePreview').classList.remove('d-none');
        updatePreview();

        // Fill Summary Panel
        document.getElementById('summaryContent').classList.remove('d-none');
        document.querySelector('#customerSummary .alert').classList.add('d-none');
        document.getElementById('summName').innerText = c.full_name;
        document.getElementById('summCode').innerText = c.customer_code;
        document.getElementById('summMobile').innerText = c.mobile;

        const balEl = document.getElementById('summBalance');
        balEl.innerText = '₹' + Math.abs(c.balance).toFixed(2);
        balEl.className = 'mb-0 ' + (c.balance >= 0 ? 'text-success' : 'text-danger');

        // Business Summary
        const bizList = document.getElementById('summBusiness');
        bizList.innerHTML = '';
        data.businessSummary.forEach(s => {
            const li = document.createElement('li');
            li.className = 'list-group-item d-flex justify-content-between align-items-center';
            li.innerHTML = `
                <span class="auto-translate">${s.business_name || 'Cash/Direct'}</span>
                <span class="${s.net_amount >= 0 ? 'text-success' : 'text-danger'} fw-bold">₹${Math.abs(s.net_amount).toFixed(2)}</span>
            `;
            bizList.appendChild(li);
        });

        // Transactions Table
        document.getElementById('customerTransactions').classList.remove('d-none');
        const tbody = document.querySelector('#lastTransTable tbody');
        tbody.innerHTML = '';
        data.lastTransactions.forEach(t => {
            const isCredit = ['milk_collection', 'owner_payment', 'customer_payment'].includes(t.type);
            const row = document.createElement('tr');
            row.innerHTML = `
                <td class="small">${t.date}</td>
                <td><span class="badge bg-light text-dark border text-uppercase">${t.type.replace('_', ' ')}</span></td>
                <td class="auto-translate">${t.business_name || 'N/A'}</td>
                <td class="${isCredit ? 'text-success' : 'text-danger'} fw-bold">₹${t.amount.toFixed(2)}</td> 
            `;
            tbody.appendChild(row);
        });
        
        // Re-run auto-translate
        if (typeof autoTranslate === 'function') autoTranslate();

    } else {
        alert(data.message);
    }
}

function updatePreview() {
    const amount = parseFloat(document.getElementById('amount').value) || 0;
    const type = document.getElementById('transType').value;

    let impact = 0;
    if (type) {
        if (['milk_collection', 'owner_payment', 'customer_payment'].includes(type)) {
            impact = amount;
        } else {
            impact = -amount;
        }
    }

    const newBalance = currentCustBalance + impact;

    const curEl = document.getElementById('currentBalance');
    curEl.innerText = '₹' + Math.abs(currentCustBalance).toFixed(2);
    curEl.className = 'fw-bold fs-5 ' + (currentCustBalance >= 0 ? 'text-success' : 'text-danger');

    const impEl = document.getElementById('impactAmount');
    impEl.innerText = (impact >= 0 ? '+' : '-') + '₹' + Math.abs(impact).toFixed(2);
    impEl.className = 'fw-bold fs-5 ' + (impact >= 0 ? 'text-success' : 'text-danger');

    const newEl = document.getElementById('newBalance');
    newEl.innerText = '₹' + Math.abs(newBalance).toFixed(2);
    newEl.className = 'fw-bold fs-5 ' + (newBalance >= 0 ? 'text-success' : 'text-danger');
}

document.getElementById('amount').addEventListener('input', updatePreview);
document.getElementById('transType').addEventListener('change', updatePreview);

// Close search results on click outside
document.addEventListener('click', function(e) {
    if (!document.getElementById('customerSearch').contains(e.target)) {
        document.getElementById('searchResults').style.display = 'none';
    }
});
</script>
