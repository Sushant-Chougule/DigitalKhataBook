<div class="row g-4">
    <!-- Left Column: Transaction Form -->
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-header bg-primary text-white"><%= __("add_transaction") %></div>
            <div class="card-body">
                <% if (success) { %>
                    <div class="alert alert-success alert-dismissible fade show">
                        <%= __(success) %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>
                <% if (error) { %>
                    <div class="alert alert-danger alert-dismissible fade show">
                        <%= __(error) %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <form action="/transactions/add" method="POST" id="transactionForm">
                    <!-- Customer Search -->
                    <div class="mb-3 position-relative">
                        <label class="form-label"><%= __("search") %> <%= __("customers") %> (<%= __("customer_code") %>, <%= __("full_name") %>, <%= __("mobile") %>)</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" id="customerSearch" class="form-control" placeholder="<%= __("search") %>..." autocomplete="off">    
                        </div>
                        <div id="searchResults" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; display: none; max-height: 200px; overflow-y: auto;"></div>
                        <input type="hidden" name="customer_id" id="customerId" required>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label"><%= __("full_name") %></label>
                            <input type="text" id="displayCustomerName" class="form-control bg-light auto-translate" readonly>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("type") %></label>
                            <select name="type" id="transType" class="form-select" required>
                                <option value=""><%= __("type") %></option>
                                <% businesses.forEach(b => { %>
                                    <% if (b.name !== 'Cash') { %>
                                        <option value="<%= b.transaction_type_name %>" data-biz-id="<%= b.id %>" data-lock="true"><%= __(b.transaction_type_name) %> (<%= b.balance_impact === 'Credit' ? '+' : '-' %>)</option>
                                    <% } %>
                                <% }) %>
                                <option value="borrowing" data-biz-id="<%= (businesses.find(b => b.name === 'Cash') || {id:''}).id %>" data-lock="false">Borrowing (-)</option>
                                <option value="settlement" data-biz-id="<%= (businesses.find(b => b.name === 'Cash') || {id:''}).id %>" data-lock="false">Settlement (+)</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("business") %></label>
                            <select name="business_id" id="businessIdSelect" class="form-select" required>
                                <option value="">Select Business</option>
                                <% businesses.forEach(b => { %>
                                    <option value="<%= b.id %>" data-name="<%= b.name %>"><%= __(b.name) %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("amount") %> (₹)</label>
                            <input type="number" step="0.01" name="amount" id="amount" class="form-control" required placeholder="0.00">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("date") %></label>
                            <input type="date" id="transDate" name="date" class="form-control" value="<%= new Date().toISOString().split('T')[0] %>">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label"><%= __("remarks") %></label>
                            <input type="text" name="remarks" id="remarks" class="form-control" placeholder="<%= __("remarks") %>">
                        </div>
                    </div>

                    <!-- Balance Preview -->
                    <div id="balancePreview" class="mt-4 p-3 border rounded-3 bg-light d-none text-dark">
                        <div class="row text-center">
                            <div class="col-md-4">
                                <small class="text-muted d-block"><%= __("balance") %></small>
                                <span id="currentBalance" class="fw-bold fs-5">₹0.00</span>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted d-block">Impact</small>
                                <span id="impactAmount" class="fw-bold fs-5">₹0.00</span>
                            </div>
                            <div class="col-md-4 border-start">
                                <small class="text-muted d-block"><%= __("net_balance") %></small>
                                <span id="newBalance" class="fw-bold fs-5">₹0.00</span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="button" class="btn btn-primary w-100 py-2 fs-5" id="saveBtn" disabled>
                            <i class="bi bi-check-circle me-2"></i> <%= __("save_transaction") %>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Recent Transactions for Selected Customer -->
        <div id="customerTransactions" class="card d-none">
            <div class="card-header"><%= __("recent_transactions") %> (<%= __("customers") %>)</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0" id="lastTransTable">
                        <thead class="bg-light">
                            <tr>
                                <th><%= __("date") %></th>
                                <th><%= __("type") %></th>
                                <th><%= __("business") %></th>
                                <th><%= __("amount") %></th>
                            </tr>
                        </thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Customer Info Panel -->
    <div class="col-md-4">
        <div id="customerSummary" class="sticky-top" style="top: 20px;">
            <div class="alert alert-info text-center py-4">
                <i class="bi bi-person-bounding-box fs-1 d-block mb-2"></i>
                Please select a customer to view summary
            </div>

            <div id="summaryContent" class="d-none">
                <div class="card mb-4 border-start border-4 border-primary">
                    <div class="card-body">
                        <h5 class="card-title mb-3 auto-translate" id="summName">--</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted"><%= __("customer_code") %>:</span>
                            <span id="summCode" class="fw-bold">--</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted"><%= __("mobile") %>:</span>
                            <span id="summMobile">--</span>
                        </div>
                        <div class="mt-3 p-3 bg-light rounded text-center text-dark">
                            <small class="text-muted"><%= __("net_balance") %></small>
                            <h3 id="summBalance" class="mb-0">₹0.00</h3>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><%= __("business_wise_summary") %></div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush" id="summBusiness">
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Transaction Confirmation Modal -->
<div class="modal fade" id="confirmTransModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Confirm Transaction</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-dark text-start">
                <p class="text-muted mb-4">Are you sure you want to save this transaction? Please review the details below:</p>
                
                <div class="row mb-3">
                    <div class="col-5 text-muted">Customer:</div>
                    <div class="col-7 fw-bold auto-translate" id="confCustomer"></div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-muted">Type:</div>
                    <div class="col-7 fw-bold" id="confType"></div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-muted">Business:</div>
                    <div class="col-7 fw-bold" id="confBusiness"></div>
                </div>
                <div class="row mb-3">
                    <div class="col-5 text-muted">Amount:</div>
                    <div class="col-7 fw-bold text-primary fs-5" id="confAmount"></div>
                </div>
                <div class="row">
                    <div class="col-5 text-muted">Date:</div>
                    <div class="col-7 fw-bold" id="confDate"></div>
                </div>
            </div>
            <div class="modal-footer border-0 p-4 pt-0">
                <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary px-4" id="confirmSaveBtn">Confirm Transaction</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    let currentCustBalance = 0;

    // Business Mapping Logic (Dynamic)
    document.getElementById('transType').addEventListener('change', function() {
        const selectedOption = this.options[this.selectedIndex];
        const bizId = selectedOption.getAttribute('data-biz-id');
        const lock = selectedOption.getAttribute('data-lock') === 'true';
        const bizSelect = document.getElementById('businessIdSelect');

        if (bizId) {
            bizSelect.value = bizId;
            bizSelect.disabled = lock;

            const oldHidden = document.getElementById('hiddenBusinessId');
            if (oldHidden) oldHidden.remove();

            if (lock) {
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'business_id';
                hiddenInput.id = 'hiddenBusinessId';
                hiddenInput.value = bizId;
                document.getElementById('transactionForm').appendChild(hiddenInput);
            }
        } else {
            bizSelect.disabled = false;
        }
        updatePreview();
    });

    document.getElementById('customerSearch').addEventListener('input', async function() {
        const query = this.value;
        const resDiv = document.getElementById('searchResults');

        if (query.length < 2) {
            resDiv.style.display = 'none';
            return;
        }

        const response = await fetch(`/customers/api/search?q=${encodeURIComponent(query)}`);
        const customers = await response.json();

        resDiv.innerHTML = '';
        if (customers.length > 0) {
            customers.forEach(c => {
                const item = document.createElement('button');
                item.type = 'button';
                item.className = 'list-group-item list-group-item-action py-2';
                item.innerHTML = `
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <strong class="d-block auto-translate">${c.full_name}</strong>
                            <small class="text-muted">${c.customer_code} | ${c.mobile}</small>
                        </div>
                    </div>
                `;
                item.onclick = () => selectCustomer(c.customer_code);
                resDiv.appendChild(item);
            });
            resDiv.style.display = 'block';
            if (typeof autoTranslate === 'function') autoTranslate();
        } else {
            resDiv.style.display = 'none';
        }
    });

    async function selectCustomer(code) {
        const resDiv = document.getElementById('searchResults');
        resDiv.style.display = 'none';
        document.getElementById('customerSearch').value = code;

        const response = await fetch(`/customers/api/${code}`);
        const data = await response.json();

        if (data.success) {
            const c = data.customer;
            currentCustBalance = c.balance;

            document.getElementById('customerId').value = c.id;
            document.getElementById('displayCustomerName').value = c.full_name;
            document.getElementById('saveBtn').disabled = false;

            document.getElementById('balancePreview').classList.remove('d-none');
            updatePreview();

            document.getElementById('summaryContent').classList.remove('d-none');
            document.querySelector('#customerSummary .alert').classList.add('d-none');
            document.getElementById('summName').innerText = c.full_name;
            document.getElementById('summCode').innerText = c.customer_code;
            document.getElementById('summMobile').innerText = c.mobile;

            const balEl = document.getElementById('summBalance');
            balEl.innerText = '₹' + Math.abs(c.balance).toFixed(2);
            balEl.className = 'mb-0 ' + (c.balance >= 0 ? 'text-success' : 'text-danger');

            const bizList = document.getElementById('summBusiness');
            bizList.innerHTML = '';
            data.businessSummary.forEach(s => {
                const li = document.createElement('li');
                li.className = 'list-group-item d-flex justify-content-between align-items-center';
                li.innerHTML = `
                    <span class="auto-translate">${s.business_name || 'Cash/Direct'}</span>
                    <span class="${s.net_amount >= 0 ? 'text-success' : 'text-danger'} fw-bold">₹${Math.abs(s.net_amount).toFixed(2)}</span>
                `;
                bizList.appendChild(li);
            });

            document.getElementById('customerTransactions').classList.remove('d-none');
            const tbody = document.querySelector('#lastTransTable tbody');
            tbody.innerHTML = '';
            data.lastTransactions.forEach(t => {
                const isCredit = ['milk_collection', 'owner_payment', 'customer_payment', 'settlement'].includes(t.type);
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td class="small">${t.date}</td>
                    <td><span class="badge bg-light text-dark border text-uppercase">${t.type.replace('_', ' ')}</span></td>
                    <td class="auto-translate">${t.business_name || 'N/A'}</td>
                    <td class="${isCredit ? 'text-success' : 'text-danger'} fw-bold">₹${t.amount.toFixed(2)}</td>
                `;
                tbody.appendChild(row);
            });

            if (typeof autoTranslate === 'function') autoTranslate();

        } else {
            alert(data.message);
        }
    }

    function updatePreview() {
        const amount = parseFloat(document.getElementById('amount').value) || 0;
        const type = document.getElementById('transType').value;
        const selectedOption = document.getElementById('transType').options[document.getElementById('transType').selectedIndex];
        
        let impact = 0;
        if (type) {
            const text = selectedOption.text.toLowerCase();
            if (text.includes('(+)') || ['milk_collection', 'settlement'].includes(type)) {
                impact = amount;
            } else {
                impact = -amount;
            }
        }

        const newBalance = currentCustBalance + impact;

        const curEl = document.getElementById('currentBalance');
        curEl.innerText = '₹' + Math.abs(currentCustBalance).toFixed(2);
        curEl.className = 'fw-bold fs-5 ' + (currentCustBalance >= 0 ? 'text-success' : 'text-danger');

        const impEl = document.getElementById('impactAmount');
        impEl.innerText = (impact >= 0 ? '+' : '-') + '₹' + Math.abs(impact).toFixed(2);
        impEl.className = 'fw-bold fs-5 ' + (impact >= 0 ? 'text-success' : 'text-danger');

        const newEl = document.getElementById('newBalance');
        newEl.innerText = '₹' + Math.abs(newBalance).toFixed(2);
        newEl.className = 'fw-bold fs-5 ' + (newBalance >= 0 ? 'text-success' : 'text-danger');
    }

    document.getElementById('amount').addEventListener('input', updatePreview);
    document.getElementById('transType').addEventListener('change', updatePreview);

    // Modal Confirmation Flow
    const confirmModal = new bootstrap.Modal(document.getElementById('confirmTransModal'));

    document.getElementById('saveBtn').addEventListener('click', function() {
        document.getElementById('confCustomer').innerText = document.getElementById('displayCustomerName').value;
        document.getElementById('confType').innerText = document.getElementById('transType').options[document.getElementById('transType').selectedIndex].text;
        document.getElementById('confBusiness').innerText = document.getElementById('businessIdSelect').options[document.getElementById('businessIdSelect').selectedIndex].text;
        document.getElementById('confAmount').innerText = '₹' + document.getElementById('amount').value;
        document.getElementById('confDate').innerText = document.getElementById('transDate').value;
        
        confirmModal.show();
    });

    document.getElementById('confirmSaveBtn').addEventListener('click', function() {
        confirmModal.hide();
        document.getElementById('businessIdSelect').disabled = false;
        document.getElementById('transactionForm').submit();
    });

    document.addEventListener('click', function(e) {
        if (!document.getElementById('customerSearch').contains(e.target)) {
            const results = document.getElementById('searchResults');
            if (results) results.style.display = 'none';
        }
    });
});</script>