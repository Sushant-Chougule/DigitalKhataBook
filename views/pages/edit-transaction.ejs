<div class="row g-4">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header bg-primary text-white"><%= __("edit") %> <%= __("transactions") %></div>
            <div class="card-body p-4">
                <% if (error) { %>
                    <div class="alert alert-danger alert-dismissible fade show">
                        <%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                <% } %>

                <form action="/transactions/edit/<%= transaction.id %>" method="POST" id="editForm">
                    <div class="row g-3">
                        <div class="col-12 mb-3">
                            <label class="form-label"><%= __("customers") %></label>
                            <input type="text" class="form-control bg-light auto-translate" value="<%= customer.full_name %> (<%= customer.customer_code %>)" readonly>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><%= __("type") %></label>
                            <select name="type" id="transType" class="form-select" required>
                                <% businesses.forEach(b => { %>
                                    <% if (b.name !== 'Cash') { %>
                                        <option value="<%= b.transaction_type_name %>" data-biz-id="<%= b.id %>" data-lock="true" <%= transaction.type === b.transaction_type_name ? 'selected' : '' %>><%= __(b.transaction_type_name) %></option>
                                    <% } %>
                                <% }) %>
                                <option value="borrowing" data-biz-id="<%= (businesses.find(b => b.name === 'Cash') || {id:''}).id %>" data-lock="false" <%= transaction.type === 'borrowing' ? 'selected' : '' %>>Borrowing (-)</option>
                                <option value="settlement" data-biz-id="<%= (businesses.find(b => b.name === 'Cash') || {id:''}).id %>" data-lock="false" <%= transaction.type === 'settlement' ? 'selected' : '' %>>Settlement (+)</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><%= __("business") %></label>
                            <select name="business_id" id="businessIdSelect" class="form-select" required>
                                <% businesses.forEach(b => { %>
                                    <option value="<%= b.id %>" data-name="<%= b.name %>" <%= transaction.business_id == b.id ? 'selected' : '' %>><%= __(b.name) %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><%= __("amount") %> (₹)</label>
                            <input type="number" step="0.01" name="amount" class="form-control" value="<%= transaction.amount %>" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label"><%= __("date") %></label>
                            <input type="date" name="date" class="form-control" value="<%= transaction.date.split('T')[0] %>" required>
                        </div>

                        <div class="col-12">
                            <label class="form-label"><%= __("remarks") %></label>
                            <input type="text" name="remarks" class="form-control" value="<%= transaction.remarks %>">
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <a href="/transactions" class="btn btn-outline-secondary px-4"><%= __("cancel") %></a>
                        <button type="submit" class="btn btn-primary px-4"><%= __("save") %></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    function applyMapping() {
        const selectedOption = document.getElementById('transType').options[document.getElementById('transType').selectedIndex];
        const bizId = selectedOption.getAttribute('data-biz-id');
        const lock = selectedOption.getAttribute('data-lock') === 'true';
        const bizSelect = document.getElementById('businessIdSelect');

        if (bizId) {
            bizSelect.value = bizId;
            bizSelect.disabled = lock;

            const oldHidden = document.getElementById('hiddenBusinessId');
            if (oldHidden) oldHidden.remove();

            if (lock) {
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'business_id';
                hiddenInput.id = 'hiddenBusinessId';
                hiddenInput.value = bizId;
                document.getElementById('editForm').appendChild(hiddenInput);
            }
        }
    }

    document.getElementById('transType').addEventListener('change', applyMapping);
    applyMapping(); // Initial run

    document.getElementById('editForm').addEventListener('submit', function() {
        document.getElementById('businessIdSelect').disabled = false;
    });
});
</script>