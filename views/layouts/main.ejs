<!DOCTYPE html>
<html lang="<%= currentLang %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __("app_name") %> - <%= title %></title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"> 
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="<%= locals.bodyClass || '' %>">
    <div class="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="bg-dark text-white">
            <div class="sidebar-header p-4 text-center">
                <h4 class="mb-0 text-primary fw-bold"><i class="bi bi-book-half me-2"></i><%= __("app_name") %></h4>
            </div>
            <ul class="list-unstyled components px-3">
                <li class="<%= path === '/dashboard' ? 'active' : '' %>">
                    <a href="/dashboard" class="nav-link"><i class="bi bi-speedometer2 me-2"></i> <%= __("dashboard") %></a> 
                </li>
                <li class="<%= path.startsWith('/customers') ? 'active' : '' %>">
                    <a href="/customers" class="nav-link"><i class="bi bi-people me-2"></i> <%= __("customers") %></a>       
                </li>
                <li class="<%= path.startsWith('/businesses') ? 'active' : '' %>">
                    <a href="/businesses" class="nav-link"><i class="bi bi-shop me-2"></i> <%= __("businesses") %></a>       
                </li>
                <li class="<%= path === '/transactions' ? 'active' : '' %>">
                    <a href="/transactions" class="nav-link"><i class="bi bi-cash-stack me-2"></i> <%= __("all_transactions") %></a>
                </li>
                <li class="<%= path === '/transactions/add' ? 'active' : '' %>">
                    <a href="/transactions/add" class="nav-link"><i class="bi bi-plus-square me-2"></i> <%= __("add_transaction") %></a>
                </li>
                <li class="<%= path.startsWith('/search') ? 'active' : '' %>">
                    <a href="/search" class="nav-link"><i class="bi bi-search me-2"></i> <%= __("global_search") %></a>      
                </li>
                <li class="<%= path.startsWith('/reports') ? 'active' : '' %>">
                    <a href="/reports" class="nav-link"><i class="bi bi-file-earmark-text me-2"></i> <%= __("reports") %></a>
                </li>
                <li class="<%= path.startsWith('/settings') ? 'active' : '' %>">
                    <a href="/settings" class="nav-link"><i class="bi bi-gear me-2"></i> <%= __("settings") %></a>
                </li>
                <li>
                    <a href="/logout" class="nav-link text-danger mt-4"><i class="bi bi-box-arrow-right me-2"></i> <%= __("logout") %></a>
                </li>
            </ul>
        </nav>

        <!-- Page Content -->
        <div id="content">
            <!-- Navbar -->
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom px-4">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-outline-secondary btn-sm me-3">   
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="navbar-brand mb-0 h1"><%= title %></span>
                    
                    <div class="ms-auto d-flex align-items-center">
                        <!-- Language Switcher -->
                        <div class="btn-group me-4 shadow-sm">
                            <a href="/change-lang/en" class="btn btn-sm <%= currentLang === 'en' ? 'btn-primary' : 'btn-outline-primary' %>">EN</a>
                            <a href="/change-lang/mr" class="btn btn-sm <%= currentLang === 'mr' ? 'btn-primary' : 'btn-outline-primary' %>">मराठी</a>
                        </div>

                        <a href="/settings" class="text-decoration-none text-muted me-3">
                            <i class="bi bi-person-circle me-1"></i> <span class="auto-translate"><%= user ? user.full_name : 'Admin' %></span>     
                        </a>
                        <div class="form-check form-switch ms-2">
                            <input class="form-check-input" type="checkbox" id="themeToggle">
                            <label class="form-check-label" for="themeToggle"><i class="bi bi-moon-stars"></i></label>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4">
                <%- body %>
            </div>
        </div>
    </div>

    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>        
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- Custom JS -->
    <script src="/js/main.js"></script>
    
    <!-- Automatic Translation Script for Marathi -->
    <% if (currentLang === 'mr') { %>
    <script>
        async function autoTranslate() {
            const elements = document.querySelectorAll('.auto-translate');
            for (let el of elements) {
                const text = el.innerText.trim();
                // Check if text is mostly English and not already translated
                if (text && /[a-zA-Z]/.test(text) && !el.dataset.translated) {
                    try {
                        const response = await fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=en|mr`);
                        const data = await response.json();
                        if (data.responseData.translatedText) {
                            el.innerText = data.responseData.translatedText;
                            el.dataset.translated = "true";
                        }
                    } catch (err) {
                        console.error('Translation error:', err);
                    }
                }
            }
        }
        document.addEventListener('DOMContentLoaded', autoTranslate);
        // Also run when DOM changes (for dynamic content)
        const observer = new MutationObserver(autoTranslate);
        observer.observe(document.body, { childList: true, subtree: true });
    </script>
    <% } %>
</body>
</html>
